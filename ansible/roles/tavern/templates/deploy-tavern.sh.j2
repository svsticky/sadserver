#!/usr/bin/env bash
# {{ ansible_managed }}

set -efuo pipefail

PROJECT_DIR="{{ tavern_home_dir }}"
cd "$PROJECT_DIR"

echo "Pulling latest images..."
docker compose pull

export $(grep -v '^#' .env | xargs)

echo "Starting containers (application will run migrations on startup)..."
docker compose up -d

# 5. Schoonmaak
docker image prune -f

echo "Deployment finished! Check logs with: docker logs -f tavern-backend"